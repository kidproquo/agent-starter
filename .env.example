# Copy to .env and fill in. .env is gitignored.

# --- LLM (litellm) ---
# `MODEL` is any litellm model string. Set the matching provider key below.
#   anthropic/claude-opus-4-8   (default)
#   openai/gpt-4o
#   gemini/gemini-1.5-pro
MODEL=anthropic/claude-opus-4-8
MAX_TOKENS=8000
REASONING_EFFORT=medium       # low|medium|high — dropped for models that don't support it
TEMPERATURE=0.2

#ANTHROPIC_API_KEY=sk-ant-
#OPENAI_API_KEY=sk-
#GEMINI_API_KEY=

# --- CORS ---
# Origins allowed to call the API with credentials (cookies). Add your frontend origin.
ALLOWED_ORIGINS=http://localhost:8300,http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---
# First admin, created/reconciled on startup so there's always a login path.
# Change the password before exposing the app.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Set true only when the app is served exclusively over HTTPS (so the session
# cookie carries the Secure flag). Leave false for plain-http access.
COOKIE_SECURE=false
# Where the SQLite DB (users/sessions/usage/config) lives. In Docker this is a
# named volume mount; locally you may want ./app.db.
DB_PATH=/data/app.db
